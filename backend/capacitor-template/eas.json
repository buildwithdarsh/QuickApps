{
  "cli": {
    "version": ">= 12.0.0",
    "requireCommit": false,
    "appVersionSource": "local"
  },
  "build": {
    "production": {
      "android": {
        "buildType": "apk",
        "image": "latest",
        "withoutCredentials": true
      }
    },
    "production-aab": {
      "android": {
        "buildType": "app-bundle",
        "image": "latest",
        "withoutCredentials": true
      }
    },
    "production-ios": {
      "ios": {
        "simulator": true,
        "image": "latest"
      }
    }
  }
}
